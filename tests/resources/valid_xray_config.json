{
  "log": {
    "access": "/var/log/xray/access.log",
    "error": "/var/log/xray/error.log",
    "loglevel": "info",
    "dnsLog": true
  },
  "dns": {
    "servers": [
      "1.0.0.1"
    ]
  },
  "inbounds": [
    {
      "listen": "0.0.0.0",
      "port": 443,
      "protocol": "vless",
      "tag": "vless-inbound",
      "settings": {
        "clients": [],
        "decryption": "none"
      },
      "streamSettings": {
        "security": "reality",
        "realitySettings": {
          "dest": "yahoo.com:443",
          "serverNames": [
            "yahoo.com"
          ],
          "privateKey": "very-secret-key",
          "shortIds": []
        }
      },
      "sniffing": {
        "enabled": false,
        "routeOnly": true,
        "destOverride": [
          "http",
          "tls",
          "quic"
        ]
      }
    }
  ],
  "routing": {
    "domainStrategy": "IPIfNonMatch",
    "rules": [
      {
        "tag": "protocol",
        "protocol": [
          "bittorrent"
        ],
        "outboundTag": "blackhole"
      },
      {
        "tag": "port",
        "port": "53",
        "outboundTag": "dns"
      },
      {
        "tag": "domain",
        "domain": [
          "cloudflare-dns.com"
        ],
        "outboundTag": "vless"
      },
      {
        "tag": "ip",
        "ip": [
          "geoip:PRIVATE"
        ],
        "outboundTag": "direct"
      }
    ]
  },
  "outbounds": [
    {
      "tag": "vless",
      "protocol": "vless",
      "settings": {
        "address": "vless-server.example.com",
        "port": 443,
        "id": "user-id",
        "encryption": "none",
        "flow": "xtls-rprx-vision"
      },
      "streamSettings": {
        "security": "reality",
        "realitySettings": {
          "serverName": "yahoo.com",
          "fingerprint": "chrome",
          "shortId": "0001",
          "password": "public-key",
          "spiderX": "/cobalt"
        }
      }
    },
    {
      "tag": "direct",
      "protocol": "freedom"
    },
    {
      "protocol": "dns",
      "settings": {
        "network": "tcp",
        "nonIPQuery": "skip"
      },
      "tag": "dns"
    },
    {
      "tag": "blackhole",
      "protocol": "blackhole"
    }
  ]
}