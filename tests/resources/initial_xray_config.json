{
  "veepeenet": {
    "host": "1.1.1.1",
    "namespace": "some-uuid"
  },
  "log": {
    "access": "/var/log/xray/access.log",
    "error": "/var/log/xray/error.log",
    "loglevel": "off",
    "dnsLog": false
  },
  "inbounds": [
    {
      "tag": "vless-inbound",
      "listen": "0.0.0.0",
      "port": 8443,
      "protocol": "vless",
      "settings": {
        "clients": [],
        "decryption": "none"
      },
      "streamSettings": {
        "realitySettings": {
          "dest": "example.com:443",
          "serverNames": [
            "example.com"
          ],
          "privateKey": "very-secret-key",
          "shortIds": []
        },
        "security": "reality"
      },
      "sniffing": {
        "enabled": false,
        "routeOnly": true,
        "destOverride": [
          "http",
          "tls",
          "quic"
        ]
      }
    }
  ],
  "outbounds": [
    {
      "tag": "direct",
      "protocol": "freedom"
    },
    {
      "tag": "blackhole",
      "protocol": "blackhole"
    },
    {
      "tag": "dns",
      "protocol": "dns",
      "settings": {
        "nonIPQuery": "skip"
      }
    }
  ]
}